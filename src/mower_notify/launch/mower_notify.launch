<launch>
    <node pkg="mower_notify" type="mower_notify.py" name="mower_notify" output="screen" respawn="true" respawn_delay="10">
        <!-- ntfy.sh topic URL. Override with OM_NTFY_URL env var or set directly here. -->
        <param name="ntfy_url" value="$(optenv OM_NTFY_URL https://ntfy.sh/mower-quiet-lynx)"/>
    </node>
</launch>
